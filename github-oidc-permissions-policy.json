{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ECRAuthorization",
      "Effect": "Allow",
      "Action": [
        "ecr:GetAuthorizationToken"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ECRRepositoryAccess",
      "Effect": "Allow",
      "Action": [
        "ecr:BatchCheckLayerAvailability",
        "ecr:CompleteLayerUpload",
        "ecr:GetDownloadUrlForLayer",
        "ecr:InitiateLayerUpload",
        "ecr:PutImage",
        "ecr:UploadLayerPart",
        "ecr:BatchGetImage",
        "ecr:DescribeImages"
      ],
      "Resource": "arn:aws:ecr:us-east-1:767925118253:repository/ai-support-app"
    },
    {
      "Sid": "ECSTaskDefinitionAccess",
      "Effect": "Allow",
      "Action": [
        "ecs:DescribeTaskDefinition",
        "ecs:RegisterTaskDefinition"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ECSServiceReadAccess",
      "Effect": "Allow",
      "Action": [
        "ecs:DescribeServices"
      ],
      "Resource": "arn:aws:ecs:us-east-1:767925118253:service/ai-support-cluster/ai-support-bg-service"
    },
    {
      "Sid": "CodeDeployBlueGreenAccess",
      "Effect": "Allow",
      "Action": [
        "codedeploy:GetApplication",
        "codedeploy:GetDeploymentGroup",
        "codedeploy:GetDeploymentConfig",
        "codedeploy:RegisterApplicationRevision",
        "codedeploy:CreateDeployment",
        "codedeploy:GetDeployment",
        "codedeploy:ListDeploymentTargets",
        "codedeploy:GetDeploymentTarget"
      ],
      "Resource": [
        "arn:aws:codedeploy:us-east-1:767925118253:application:ai-support-codedeploy-app",
        "arn:aws:codedeploy:us-east-1:767925118253:deploymentgroup:ai-support-codedeploy-app/ai-support-deployment-group",
        "arn:aws:codedeploy:us-east-1:767925118253:deploymentconfig:*"
      ]
    },
    {
      "Sid": "PassECSTaskRoles",
      "Effect": "Allow",
      "Action": [
        "iam:PassRole"
      ],
      "Resource": [
        "arn:aws:iam::767925118253:role/ai-support-app-task-role",
        "arn:aws:iam::767925118253:role/ecsTaskExecutionRole1"
      ]
    }
  ]
}
